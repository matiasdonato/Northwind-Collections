# Puerto de la API
PORT=3000

# Conexión a PostgreSQL (valores por defecto del docker-compose de la raíz)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=northwind
DATABASE_PASSWORD=northwind
DATABASE_NAME=northwind_collections

# Origen permitido para CORS (URL del frontend en desarrollo)
CORS_ORIGIN=http://localhost:5173
